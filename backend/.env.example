# ---------------------------------------------------------------------------
# SoundGuard AI – Environment Variables
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------------------

# Application
PROJECT_NAME="SoundGuard AI"
VERSION="1.0.0"

# Database  (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./soundguard.db
# DATABASE_URL=postgresql://user:password@localhost:5432/soundguard

# File storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800   # 50 MB

# CORS – comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173"]
